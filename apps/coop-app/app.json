{
  "expo": {
    "name": "coop-app",
    "slug": "coop-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "jani-coop-app",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#065F46"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.janiai.coopapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "This app uses the camera to scan QR codes for farmer verification."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#065F46"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.janiai.coopapp",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow JANI Coop to access your camera for QR code scanning."
        }
      ]
    ],
    "extra": {
      "router": {}
    }
  }
}
