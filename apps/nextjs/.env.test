# Environment variables for local test/CI runs
# This file is safe to commit because it contains only local/test defaults and no real secrets.

# Server-side
DATABASE_URL="postgresql://postgres:password@localhost:5432/kilimo_test"
DIRECT_URL="postgresql://postgres:password@localhost:5432/kilimo_test"
NODE_ENV="test"

# Optional service keys (left empty for local testing)
SUPABASE_SERVICE_KEY=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Client-side (must start with NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
